{
  "extends": "./tsconfig.json",
  "include": [
    "packages",
    "scripts",
    "types",
    "jest",
    "@testing-library/jest-dom",
    "@testing-library/jest-dom/jest-globals"
  ],
  "compilerOptions": {
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react",
    "typeRoots": [
      "./node_modules/@types",
      "./types",
      "@testing-library/jest-dom",
      "@testing-library/jest-dom/jest-globals"
    ]
  }
}
